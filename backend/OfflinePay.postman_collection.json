{
	"info": {
		"_postman_id": "offline-pay-backend-tests",
		"name": "OfflinePay API",
		"description": "Complete collection for testing OfflinePay backend endpoints.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"phone\": \"+919876543210\",\n    \"password\": \"password123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/api/auth/register"
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/api/auth/login"
					}
				}
			]
		},
		{
			"name": "Wallet",
			"item": [
				{
					"name": "Get Balance",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": "{{base_url}}/api/wallet/balance"
					}
				}
			]
		},
		{
			"name": "Sync Engine",
			"item": [
				{
					"name": "Validate Token",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"txn\": {\n        \"id\": \"TXN_12345\",\n        \"senderId\": \"john@example.com\",\n        \"receiverId\": \"receiver@example.com\",\n        \"amount\": 500,\n        \"expiresAt\": \"2026-12-31T23:59:59Z\",\n        \"signature\": \"valid_signature_string\"\n    }\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/api/sync/validate"
					}
				}
			]
		},
		{
			"name": "History",
			"item": [
				{
					"name": "Get Transactions",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": {
							"raw": "{{base_url}}/api/transactions/history?page=1&limit=10",
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" }
							]
						}
					}
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": { "type": "text/javascript", "exec": [ "" ] }
		},
		{
			"listen": "test",
			"script": { "type": "text/javascript", "exec": [ "" ] }
		}
	],
	"variable": [
		{ "key": "base_url", "value": "http://localhost:5000" },
		{ "key": "jwt_token", "value": "paste_token_here" }
	]
}
